# ─────────────────────────────────────────────────────────────────────────────
# NovaOPS — environment configuration
# Copy this file to .env and adjust values before starting.
# ─────────────────────────────────────────────────────────────────────────────

# Django secret key — generate a new one with:
#   python -c "import secrets; print(secrets.token_urlsafe(60))"
DJANGO_SECRET_KEY=change-me-generate-a-real-secret-key

# Set to false in production
DJANGO_DEBUG=true

# Comma-separated hostnames / IPs that Django will serve.
# For local Docker: leave as localhost. For a server, add your domain.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Set to true only if running behind HTTPS (enables HSTS, secure cookies, SSL redirect)
DJANGO_SSL_REDIRECT=false

# ── Admin account ─────────────────────────────────────────────────────────────
# Created automatically on first start if it doesn't already exist.
ADMIN_EMAIL=admin@novaops.local
ADMIN_PASSWORD=novaops123

# ── Demo data ─────────────────────────────────────────────────────────────────
# Set to false to skip loading demo data on startup.
LOAD_DEMO_DATA=true

# ── Optional ──────────────────────────────────────────────────────────────────
# Number of Gunicorn worker processes (default: 3)
# GUNICORN_WORKERS=3

# External port to bind (default: 8000)
# PORT=8000
